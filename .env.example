# Список ключей opencode-go (через запятую)
OPENCODE_KEYS=key1,key2,key3

# Пути к файлам настроек для обновления (через запятую)
CONFIG_FILES=/path/to/.env1,/path/to/.env2

# Интервал обновления статистики (в секундах)
STATS_UPDATE_INTERVAL=3600

# Файл для хранения статистики
STATS_FILE=./data/stats.json

# Включить отладочное логирование
DEBUG=false
